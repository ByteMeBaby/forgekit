{
  "name": "@forgekit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx src/scripts/reset.ts",
    "db:test-reset": "tsx src/scripts/reset.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgekit/config": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@forgekit/typescript-config": "workspace:*",
    "@forgekit/vitest-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0"
  }
}
