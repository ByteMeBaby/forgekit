# ForgeKit environment template. Copy to .env and adjust as needed.
# A fresh clone boots on these defaults with no real secrets set.

# Runtime environment. One of: development | production | test
NODE_ENV=development

# App shape. One of: personal | personal_and_org | org
APP_SHAPE=personal_and_org

# Session secret, minimum 32 characters. Uncomment and set a strong random value
# before enabling auth. Leave unset to boot without auth.
# AUTH_SECRET=

# Require a verified email before sign-in. One of: true | false
# AUTH_REQUIRE_EMAIL_VERIFICATION=false
