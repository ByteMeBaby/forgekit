{
  "name": "@forgekit/eslint-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "eslint": "^9.30.1"
  },
  "devDependencies": {
    "@forgekit/typescript-config": "workspace:*",
    "@forgekit/vitest-config": "workspace:*",
    "@types/estree": "^1.0.8",
    "@types/node": "^26.1.0",
    "eslint": "^9.30.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
